# PostgreSQL (required for Prisma and API)
# Example: postgresql://USER:PASSWORD@localhost:5432/DATABASE_NAME
DATABASE_URL=

# JWT secrets (required for API auth)
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# Optional: API server
PORT=4000
CORS_ORIGINS=http://localhost:3000,http://localhost:4000

# Optional: Web app
NEXT_PUBLIC_API_URL=http://localhost:4000
