{
  "name": "apis",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "node --watch --import tsx src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "pnpm exec vitest run",
    "test:watch": "pnpm exec vitest",
    "db:generate": "prisma generate",
